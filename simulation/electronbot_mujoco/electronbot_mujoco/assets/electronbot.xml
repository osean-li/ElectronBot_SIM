<?xml version="1.0" encoding="utf-8"?>
<!--
  ElectronBot MuJoCo MJCF 模型文件
  6-DOF 双臂桌面机器人

  ====== 关节约定 (模型角度) ======
  joint 0: body       [-90°, 90°]   Y轴 腰部旋转
  joint 1: head       [-15°, 15°]   X轴 头部俯仰
  joint 2: left_pitch [-20°, 180°]  X轴 左臂俯仰
  joint 3: left_roll  [0°, 30°]     Z轴 左臂roll
  joint 4: right_pitch[-20°, 180°]  X轴 右臂俯仰
  joint 5: right_roll [0°, 30°]     Z轴 右臂roll

  ====== 执行器 ======
  - 6 个 position actuator (对应每个 revolute joint)
  - 用于 position control 模式
  - 同时保留 motor actuator 用于 impedance control 模式

  ====== 传感器 ======
  - IMU (accelerometer + gyroscope) 在 head link
  - RGB-D camera (240x240) 在头部前方
-->

<mujoco model="electronbot">
  <compiler angle="radian" meshdir="../../electronbot_description/meshes"
            autolimits="true"/>

  <!-- ==================== 默认设置 ==================== -->
  <default>
    <!-- 关节默认 (参考 hardware_reference.md §10.3 domain rand 基线: damping 5-20) -->
    <joint damping="5" armature="0.005" frictionloss="0.1"/>
    <!-- 位置执行器默认 (DCE 模式时不使用; 基础模式使用各关节独立 kp) -->
    <position kp="10" ctrllimited="true"/>
    <!-- 力矩电机默认 (用于 DCE PID torque control) -->
    <motor ctrllimited="true"/>
    <!-- 几何体默认 -->
    <geom contype="1" conaffinity="1" condim="3" friction="0.5 0.1 0.1"/>
  </default>

  <!-- ==================== 材质 ==================== -->
  <asset>
    <texture name="tex_ground" type="2d" builtin="checker"
             width="512" height="512"
             rgb1="0.2 0.2 0.2" rgb2="0.3 0.3 0.3"/>
    <material name="mat_ground" texture="tex_ground" reflectance="0.2"/>
    <material name="mat_base" rgba="0.2 0.2 0.2 1.0"/>
    <material name="mat_body" rgba="0.85 0.85 0.85 1.0"/>
    <material name="mat_head" rgba="0.3 0.3 0.3 1.0"/>
    <material name="mat_arm" rgba="0.6 0.6 0.6 1.0"/>
    <material name="mat_camera" rgba="0.0 0.0 0.0 1.0"/>
    <material name="mat_target" rgba="1.0 0.2 0.2 0.6"/>
  </asset>

  <!-- ==================== 世界体 (运动学树) ==================== -->
  <worldbody>
    <!-- 地面 -->
    <geom name="floor" type="plane" size="0.5 0.5 0.05" material="mat_ground"/>

    <!-- 光照 -->
    <light name="light_main" directional="true"
           pos="0.3 -0.5 0.8" dir="0 -0.5 -1"/>

    <!-- ====== base_link (固定基座) ====== -->
    <body name="base_link" pos="0 0 0.015">
      <geom name="base_geom" type="box" size="0.035 0.032 0.015"
            material="mat_base"/>
      <site name="base_site" pos="0 0 0" size="0.005"/>

      <!-- ====== body (腰部 Y轴旋转) ====== -->
      <body name="body" pos="0 0 0.03">
        <joint name="body_joint" type="hinge" axis="0 1 0"
               range="-1.5708 1.5708" limited="true"/>
        <geom name="body_geom" type="cylinder" size="0.025 0.035"
              pos="0 0 0.035" material="mat_body"/>
        <site name="body_site" pos="0 0 0.07" size="0.005"/>

        <!-- ====== head (X轴俯仰) ====== -->
        <body name="head" pos="0 0 0.07">
          <joint name="head_joint" type="hinge" axis="1 0 0"
                 range="-0.2618 0.2618" limited="true"/>
          <geom name="head_geom" type="box" size="0.02 0.0175 0.02"
                pos="0 0 0.02" material="mat_head"/>
          <site name="head_site" pos="0 0 0.04" size="0.005"/>

          <!-- IMU 传感器位置 -->
          <site name="imu_site" pos="0 0 0.02" size="0.003"/>

          <!-- D435 仿真相机位置 -->
          <body name="camera_body" pos="0 0.0175 0.025">
            <geom name="camera_geom" type="box" size="0.0125 0.0075 0.005"
                  material="mat_camera"/>
            <site name="camera_site" pos="0 0 0.005" size="0.003"/>
            <!-- 相机 frame (z-forward, y-down convention) -->
            <camera name="d435_camera" pos="0 0 0.005"
                    zaxis="0 0 1" resolution="240 240" fovy="60"/>
          </body>
        </body>

        <!-- ====== 左臂链 ====== -->
        <body name="left_shoulder" pos="0.025 0 0.065">
          <joint name="left_shoulder_joint" type="hinge" axis="1 0 0"
                 range="-0.3491 3.1416" limited="true"/>
          <geom name="left_shoulder_geom" type="box" size="0.01 0.015 0.015"
                pos="0 0.01 0" material="mat_arm"/>
          <site name="left_shoulder_site" pos="0 0.03 0" size="0.005"/>

          <!-- 左臂末端 -->
          <body name="left_arm" pos="0 0.03 0">
            <joint name="left_arm_roll_joint" type="hinge" axis="0 0 1"
                   range="0 0.5236" limited="true"/>
            <geom name="left_arm_geom" type="cylinder" size="0.008 0.025"
                  pos="0 -0.025 0" material="mat_arm"/>
            <!-- 左臂末端执行器位置标记 -->
            <site name="left_ee_site" pos="0 -0.055 0" size="0.008"/>
          </body>
        </body>

        <!-- ====== 右臂链 ====== -->
        <body name="right_shoulder" pos="-0.025 0 0.065">
          <joint name="right_shoulder_joint" type="hinge" axis="1 0 0"
                 range="-0.3491 3.1416" limited="true"/>
          <geom name="right_shoulder_geom" type="box" size="0.01 0.015 0.015"
                pos="0 0.01 0" material="mat_arm"/>
          <site name="right_shoulder_site" pos="0 0.03 0" size="0.005"/>

          <!-- 右臂末端 -->
          <body name="right_arm" pos="0 0.03 0">
            <joint name="right_arm_roll_joint" type="hinge" axis="0 0 1"
                   range="0 0.5236" limited="true"/>
            <geom name="right_arm_geom" type="cylinder" size="0.008 0.025"
                  pos="0 -0.025 0" material="mat_arm"/>
            <!-- 右臂末端执行器位置标记 -->
            <site name="right_ee_site" pos="0 -0.055 0" size="0.008"/>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <!-- ==================== 执行器 ==================== -->
  <!--
    kp/kv/forcement: hardware_reference.md §7.3 + §3.4
    基础模式: position actuator (低 kp, forcerange 防止 DCE 模式时打架)
    固件模式: motor actuator (DCE PID torque, 200Hz)
    两套执行器作用在同一关节上, 必须通过 forcerange 限制 position 的干预
  -->
  <actuator>
    <!-- 位置控制执行器 (6个) - 基础模式; 固件模式下 negligible (forcerange=0.01) -->
    <position name="act_body"          joint="body_joint"            kp="5" kv="1" forcerange="-0.01 0.01" ctrlrange="-1.5708 1.5708"/>
    <position name="act_head"          joint="head_joint"            kp="3" kv="1" forcerange="-0.01 0.01" ctrlrange="-0.2618 0.2618"/>
    <position name="act_left_shoulder"  joint="left_shoulder_joint"  kp="5" kv="1" forcerange="-0.01 0.01" ctrlrange="-0.3491 3.1416"/>
    <position name="act_left_arm_roll" joint="left_arm_roll_joint"   kp="5" kv="1" forcerange="-0.01 0.01" ctrlrange="0 0.5236"/>
    <position name="act_right_shoulder" joint="right_shoulder_joint" kp="5" kv="1" forcerange="-0.01 0.01" ctrlrange="-0.3491 3.1416"/>
    <position name="act_right_arm_roll" joint="right_arm_roll_joint" kp="5" kv="1" forcerange="-0.01 0.01" ctrlrange="0 0.5236"/>

    <!-- 力矩电机 (6个) - DCE PID / impedance 模式; forcerange 对应实机 torque_limit × PWM_max/1000 × 0.3Nm -->
    <motor name="motor_body"           joint="body_joint"            ctrlrange="-0.5 0.5"/>
    <motor name="motor_head"           joint="head_joint"            ctrlrange="-0.25 0.25"/>
    <motor name="motor_left_shoulder"  joint="left_shoulder_joint"   ctrlrange="-0.5 0.5"/>
    <motor name="motor_left_arm_roll"  joint="left_arm_roll_joint"   ctrlrange="-1.0 1.0"/>
    <motor name="motor_right_shoulder" joint="right_shoulder_joint"  ctrlrange="-0.5 0.5"/>
    <motor name="motor_right_arm_roll" joint="right_arm_roll_joint"  ctrlrange="-1.0 1.0"/>
  </actuator>

  <!-- ==================== 传感器 ==================== -->
  <sensor>
    <!-- IMU (accelerometer + gyroscope) -->
    <accelerometer name="imu_accel" site="imu_site"/>
    <gyro name="imu_gyro" site="imu_site"/>

    <!-- 关节位置 (6个) -->
    <jointpos name="jpos_body"            joint="body_joint"/>
    <jointpos name="jpos_head"            joint="head_joint"/>
    <jointpos name="jpos_left_shoulder"   joint="left_shoulder_joint"/>
    <jointpos name="jpos_left_arm_roll"   joint="left_arm_roll_joint"/>
    <jointpos name="jpos_right_shoulder"  joint="right_shoulder_joint"/>
    <jointpos name="jpos_right_arm_roll"  joint="right_arm_roll_joint"/>

    <!-- 关节速度 (6个) -->
    <jointvel name="jvel_body"            joint="body_joint"/>
    <jointvel name="jvel_head"            joint="head_joint"/>
    <jointvel name="jvel_left_shoulder"   joint="left_shoulder_joint"/>
    <jointvel name="jvel_left_arm_roll"   joint="left_arm_roll_joint"/>
    <jointvel name="jvel_right_shoulder"  joint="right_shoulder_joint"/>
    <jointvel name="jvel_right_arm_roll"  joint="right_arm_roll_joint"/>

    <!-- 末端执行器位置 (6D: left_ee + right_ee) -->
    <framepos name="left_ee_pos"  objtype="site" objname="left_ee_site"/>
    <framepos name="right_ee_pos" objtype="site" objname="right_ee_site"/>

    <!-- 仿真相机 (RGB-D) 位于 d435_camera 对象 -->
    <!-- MuJoCo 原生 camera 渲染输出由 scene.xml 中的 visual 节点控制 -->
  </sensor>
</mujoco>
