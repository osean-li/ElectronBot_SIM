<?xml version="1.0"?>
<!--
  ElectronBot URDF 机器人描述文件

  ====== 运动学链 (Kinematic Chain) ======
  基于 Unity Prefab 分析 (ElectronBot.prefab):

  base_link (root, fixed)
    └── body_joint [revolute, Y轴] ──► body
          ├── head_joint [revolute, X轴] ──► head
          ├── left_shoulder_joint [revolute, X轴] ──► left_shoulder
          │     └── left_arm_roll_joint [revolute, Z轴] ──► left_arm
          └── right_shoulder_joint [revolute, X轴] ──► right_shoulder
                └── right_arm_roll_joint [revolute, Z轴] ──► right_arm

  ====== 关节参数 (来自固件 robot.h) ======
  joint               | 模型角度范围       | 机械角度范围     | 轴
  -------------------|-------------------|-----------------|-----
  head               | -15° ~ 15°        | 70° ~ 95°       | X
  left_arm_roll      | 0° ~ 30°          | -9° ~ 3°        | Z
  left_arm_pitch     | -20° ~ 180°       | -16° ~ 117°     | X
  right_arm_roll     | 0° ~ 30°          | 133° ~ 141°     | Z
  right_arm_pitch    | -20° ~ 180°       | 15° ~ 150°      | X
  body               | -90° ~ 90°        | 0° ~ 180°       | Y

  ====== 坐标系约定 ======
  使用 ROS 坐标系: Z-up, X-forward, Y-left
  位置单位: 米 (m)
  角度单位: 弧度 (rad), 文件中以度表示方便阅读

  ====== 注意 ======
  - 当前使用几何基元 (box/cylinder) 作为可视化形状
  - 后续需用 FreeCAD 导出 STL 替换为精确网格
-->
<robot name="electronbot">

  <!-- ==================== 根连杆: base_link ==================== -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.015" rpy="0 0 0"/>
      <geometry>
        <box size="0.07 0.064 0.03"/>
      </geometry>
      <material name="dark_grey">
        <color rgba="0.2 0.2 0.2 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.015" rpy="0 0 0"/>
      <geometry>
        <box size="0.07 0.064 0.03"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.015" rpy="0 0 0"/>
      <mass value="0.15"/>
      <!-- Box inertia: m/12 * (y²+z²), m/12 * (x²+z²), m/12 * (x²+y²) -->
      <inertia
        ixx="0.0000625" iyy="0.0000650" izz="0.0001175"
        ixy="0.0" ixz="0.0" iyz="0.0"/>
    </inertial>
  </link>

  <!-- ==================== body_joint (腰部 Y轴旋转) ==================== -->
  <joint name="body_joint" type="revolute">
    <origin xyz="0 0 0.03" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="body"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.5708" upper="1.5708" effort="2.0" velocity="3.14"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>

  <!-- ==================== 躯干: body ==================== -->
  <link name="body">
    <visual>
      <origin xyz="0 0 0.035" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.025" length="0.07"/>
      </geometry>
      <material name="white">
        <color rgba="0.9 0.9 0.9 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.035" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.025" length="0.07"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.035" rpy="0 0 0"/>
      <mass value="0.12"/>
      <inertia
        ixx="0.0000883" iyy="0.0000375" izz="0.0000883"
        ixy="0.0" ixz="0.0" iyz="0.0"/>
    </inertial>
  </link>

  <!-- ==================== head_joint (头部 X轴俯仰) ==================== -->
  <joint name="head_joint" type="revolute">
    <origin xyz="0 0 0.07" rpy="0 0 0"/>
    <parent link="body"/>
    <child link="head"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.2618" upper="0.2618" effort="1.0" velocity="3.14"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>

  <!-- ==================== 头部: head ==================== -->
  <link name="head">
    <visual>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.035 0.04"/>
      </geometry>
      <material name="grey">
        <color rgba="0.3 0.3 0.3 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.035 0.04"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <mass value="0.08"/>
      <inertia
        ixx="0.0000244" iyy="0.0000187" izz="0.0000244"
        ixy="0.0" ixz="0.0" iyz="0.0"/>
    </inertial>
  </link>

  <!-- ============ 左手: left_shoulder_joint (X轴俯仰) ============ -->
  <joint name="left_shoulder_joint" type="revolute">
    <origin xyz="0.025 0 0.065" rpy="0 0 0"/>
    <parent link="body"/>
    <child link="left_shoulder"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.3491" upper="3.1416" effort="1.0" velocity="3.14"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>

  <!-- ==================== 左肩 ==================== -->
  <link name="left_shoulder">
    <visual>
      <origin xyz="0 0.01 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.02 0.03 0.03"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <origin xyz="0 0.01 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.02 0.03 0.03"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0.01 0" rpy="0 0 0"/>
      <mass value="0.03"/>
      <inertia
        ixx="0.0000038" iyy="0.0000031" izz="0.0000031"
        ixy="0.0" ixz="0.0" iyz="0.0"/>
    </inertial>
  </link>

  <!-- ============ 左手: left_arm_roll_joint (Z轴 roll) ============ -->
  <joint name="left_arm_roll_joint" type="revolute">
    <origin xyz="0 0.03 0" rpy="0 0 0"/>
    <parent link="left_shoulder"/>
    <child link="left_arm"/>
    <axis xyz="0 0 1"/>
    <limit lower="0.0" upper="0.5236" effort="1.0" velocity="3.14"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>

  <!-- ==================== 左臂 (末端) ==================== -->
  <link name="left_arm">
    <visual>
      <origin xyz="0 -0.025 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.008" length="0.05"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <origin xyz="0 -0.025 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.008" length="0.05"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 -0.025 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia
        ixx="0.0000117" iyy="0.0000117" izz="0.0000016"
        ixy="0.0" ixz="0.0" iyz="0.0"/>
    </inertial>
  </link>

  <!-- ============ 右手: right_shoulder_joint (X轴俯仰) ============ -->
  <joint name="right_shoulder_joint" type="revolute">
    <origin xyz="-0.025 0 0.065" rpy="0 0 0"/>
    <parent link="body"/>
    <child link="right_shoulder"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.3491" upper="3.1416" effort="1.0" velocity="3.14"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>

  <!-- ==================== 右肩 ==================== -->
  <link name="right_shoulder">
    <visual>
      <origin xyz="0 0.01 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.02 0.03 0.03"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <origin xyz="0 0.01 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.02 0.03 0.03"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0.01 0" rpy="0 0 0"/>
      <mass value="0.03"/>
      <inertia
        ixx="0.0000038" iyy="0.0000031" izz="0.0000031"
        ixy="0.0" ixz="0.0" iyz="0.0"/>
    </inertial>
  </link>

  <!-- ============ 右手: right_arm_roll_joint (Z轴 roll) ============ -->
  <joint name="right_arm_roll_joint" type="revolute">
    <origin xyz="0 0.03 0" rpy="0 0 0"/>
    <parent link="right_shoulder"/>
    <child link="right_arm"/>
    <axis xyz="0 0 1"/>
    <limit lower="0.0" upper="0.5236" effort="1.0" velocity="3.14"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>

  <!-- ==================== 右臂 (末端) ==================== -->
  <link name="right_arm">
    <visual>
      <origin xyz="0 -0.025 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.008" length="0.05"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <origin xyz="0 -0.025 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.008" length="0.05"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 -0.025 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia
        ixx="0.0000117" iyy="0.0000117" izz="0.0000016"
        ixy="0.0" ixz="0.0" iyz="0.0"/>
    </inertial>
  </link>

  <!-- ==================== D435 仿真相机 (头部前方) ==================== -->
  <joint name="camera_joint" type="fixed">
    <origin xyz="0 0.0175 0.025" rpy="0 0 0"/>
    <parent link="head"/>
    <child link="camera_link"/>
  </joint>

  <link name="camera_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.025 0.015 0.01"/>
      </geometry>
      <material name="black">
        <color rgba="0.0 0.0 0.0 1.0"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="1e-6" iyy="1e-6" izz="1e-6" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

</robot>
