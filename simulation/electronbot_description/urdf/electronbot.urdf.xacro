<?xml version="1.0"?>
<!--
  ElectronBot URDF (xacro 参数化版本)
  使用 materials.xacro 中定义的宏构建，支持参数化调整
-->
<robot name="electronbot" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:include filename="materials.xacro"/>

  <!-- ============ 根连杆: base_link ============ -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.015" rpy="0 0 0"/>
      <geometry><box size="0.07 0.064 0.03"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.015" rpy="0 0 0"/>
      <geometry><box size="0.07 0.064 0.03"/></geometry>
    </collision>
    <xacro:box_inertial mass="${base_mass}" x="0.07" y="0.064" z="0.03"/>
  </link>

  <!-- ============ 躯干: body (Y轴腰部旋转) ============ -->
  <xacro:robot_joint name="body_joint"
    parent="base_link" child="body"
    axis="0 1 0" lower="-1.5708" upper="1.5708"
    effort="2.0" velocity="3.14"
    origin_xyz="0 0 0.03" origin_rpy="0 0 0"/>

  <link name="body">
    <visual>
      <origin xyz="0 0 0.035" rpy="0 0 0"/>
      <geometry><cylinder radius="0.025" length="0.07"/></geometry>
      <material name="body_color"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.035" rpy="0 0 0"/>
      <geometry><cylinder radius="0.025" length="0.07"/></geometry>
    </collision>
    <xacro:box_inertial mass="${body_mass}" x="0.05" y="0.05" z="0.07"/>
  </link>

  <!-- ============ 头部: head (X轴俯仰) ============ -->
  <xacro:robot_joint name="head_joint"
    parent="body" child="head"
    axis="1 0 0" lower="-0.2618" upper="0.2618"
    effort="1.0" velocity="3.14"
    origin_xyz="0 0 0.07" origin_rpy="0 0 0"/>

  <link name="head">
    <visual>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <geometry><box size="0.04 0.035 0.04"/></geometry>
      <material name="head_color"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <geometry><box size="0.04 0.035 0.04"/></geometry>
    </collision>
    <xacro:box_inertial mass="${head_mass}" x="0.04" y="0.035" z="0.04"/>
  </link>

  <!-- D435 相机 (头部前方) -->
  <xacro:d435_camera parent="head" name="d435"
    xyz="0 0.0175 0.025" rpy="0 0 0"/>

  <!-- ============ 左臂链 ============ -->
  <xacro:robot_joint name="left_shoulder_joint"
    parent="body" child="left_shoulder"
    axis="1 0 0" lower="-0.3491" upper="3.1416"
    effort="1.0" velocity="3.14"
    origin_xyz="0.025 0 0.065" origin_rpy="0 0 0"/>

  <link name="left_shoulder">
    <visual>
      <origin xyz="0 0.01 0" rpy="0 0 0"/>
      <geometry><box size="0.02 0.03 0.03"/></geometry>
      <material name="arm_color"/>
    </visual>
    <collision>
      <origin xyz="0 0.01 0" rpy="0 0 0"/>
      <geometry><box size="0.02 0.03 0.03"/></geometry>
    </collision>
    <xacro:box_inertial mass="${shoulder_mass}" x="0.02" y="0.03" z="0.03"/>
  </link>

  <xacro:robot_joint name="left_arm_roll_joint"
    parent="left_shoulder" child="left_arm"
    axis="0 0 1" lower="0" upper="0.5236"
    effort="1.0" velocity="3.14"
    origin_xyz="0 0.03 0" origin_rpy="0 0 0"/>

  <link name="left_arm">
    <visual>
      <origin xyz="0 -0.025 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.008" length="0.05"/></geometry>
      <material name="arm_color"/>
    </visual>
    <collision>
      <origin xyz="0 -0.025 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.008" length="0.05"/></geometry>
    </collision>
    <xacro:box_inertial mass="${arm_mass}" x="0.016" y="0.05" z="0.016"/>
  </link>

  <!-- ============ 右臂链 ============ -->
  <xacro:robot_joint name="right_shoulder_joint"
    parent="body" child="right_shoulder"
    axis="1 0 0" lower="-0.3491" upper="3.1416"
    effort="1.0" velocity="3.14"
    origin_xyz="-0.025 0 0.065" origin_rpy="0 0 0"/>

  <link name="right_shoulder">
    <visual>
      <origin xyz="0 0.01 0" rpy="0 0 0"/>
      <geometry><box size="0.02 0.03 0.03"/></geometry>
      <material name="arm_color"/>
    </visual>
    <collision>
      <origin xyz="0 0.01 0" rpy="0 0 0"/>
      <geometry><box size="0.02 0.03 0.03"/></geometry>
    </collision>
    <xacro:box_inertial mass="${shoulder_mass}" x="0.02" y="0.03" z="0.03"/>
  </link>

  <xacro:robot_joint name="right_arm_roll_joint"
    parent="right_shoulder" child="right_arm"
    axis="0 0 1" lower="0" upper="0.5236"
    effort="1.0" velocity="3.14"
    origin_xyz="0 0.03 0" origin_rpy="0 0 0"/>

  <link name="right_arm">
    <visual>
      <origin xyz="0 -0.025 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.008" length="0.05"/></geometry>
      <material name="arm_color"/>
    </visual>
    <collision>
      <origin xyz="0 -0.025 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.008" length="0.05"/></geometry>
    </collision>
    <xacro:box_inertial mass="${arm_mass}" x="0.016" y="0.05" z="0.016"/>
  </link>

</robot>
