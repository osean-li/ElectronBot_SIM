<?xml version="1.0"?>
<!--
  ElectronBot 材料属性与惯性参数宏定义
  使用 xacro 宏简化 URDF 参数管理

  关节约定 (来自固件 robot.h 和 Unity Prefab 分析):
    joint 名称                 | 类型   | 父连杆      | 子连杆         | 轴   | 角度范围
    ---------------------------|--------|-------------|----------------|------|--------------
    body_joint (腰部)          | revolute | base_link | body          | Y    | -90° ~ 90°
    head_joint                 | revolute | body       | head          | X    | -15° ~ 15°
    left_shoulder_joint        | revolute | body       | left_shoulder | X    | -20° ~ 180°
    left_arm_roll_joint        | revolute | left_shoulder | left_arm    | Z    | 0° ~ 30°
    right_shoulder_joint       | revolute | body       | right_shoulder| X    | -20° ~ 180°
    right_arm_roll_joint       | revolute | right_shoulder| right_arm  | Z    | 0° ~ 30°
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ============ 连杆质量定义 (单位: kg) ============ -->
  <xacro:property name="base_mass" value="0.15"/>
  <xacro:property name="body_mass" value="0.12"/>
  <xacro:property name="head_mass" value="0.08"/>
  <xacro:property name="shoulder_mass" value="0.03"/>
  <xacro:property name="arm_mass" value="0.05"/>

  <!-- ============ 默认颜色 ============ -->
  <xacro:property name="base_color" value="0.2 0.2 0.2 1.0"/>
  <xacro:property name="body_color" value="0.9 0.9 0.9 1.0"/>
  <xacro:property name="head_color" value="0.3 0.3 0.3 1.0"/>
  <xacro:property name="arm_color" value="0.7 0.7 0.7 1.0"/>

  <!-- ============ 惯性宏: Box ============ -->
  <xacro:macro name="box_inertial" params="mass x y z">
    <!-- 简化处理: 将连杆视为均质长方体计算惯性张量 -->
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="${mass}"/>
      <inertia
        ixx="${mass / 12.0 * (y*y + z*z)}"
        iyy="${mass / 12.0 * (x*x + z*z)}"
        izz="${mass / 12.0 * (x*x + y*y)}"
        ixy="0.0" ixz="0.0" iyz="0.0"/>
    </inertial>
  </xacro:macro>

  <!-- ============ 回转关节宏 (revolute) ============ -->
  <xacro:macro name="robot_joint"
    params="name parent child axis lower upper effort velocity origin_xyz origin_rpy">
    <joint name="${name}" type="revolute">
      <origin xyz="${origin_xyz}" rpy="${origin_rpy}"/>
      <parent link="${parent}"/>
      <child link="${child}"/>
      <axis xyz="${axis}"/>
      <limit lower="${lower}" upper="${upper}"
             effort="${effort}" velocity="${velocity}"/>
      <dynamics damping="0.5" friction="0.1"/>
    </joint>
  </xacro:macro>

  <!-- ============ 传感器宏: IMU ============ -->
  <xacro:macro name="imu_sensor" params="link reference">
    <gazebo reference="${reference}">
      <sensor name="imu_sensor_${link}" type="imu">
        <always_on>true</always_on>
        <update_rate>100.0</update_rate>
        <imu>
          <angular_velocity>
            <x><noise type="gaussian" mean="0.0" stddev="1e-4"/></x>
            <y><noise type="gaussian" mean="0.0" stddev="1e-4"/></y>
            <z><noise type="gaussian" mean="0.0" stddev="1e-4"/></z>
          </angular_velocity>
          <linear_acceleration>
            <x><noise type="gaussian" mean="0.0" stddev="1e-2"/></x>
            <y><noise type="gaussian" mean="0.0" stddev="1e-2"/></y>
            <z><noise type="gaussian" mean="0.0" stddev="1e-2"/></z>
          </linear_acceleration>
        </imu>
      </sensor>
    </gazebo>
  </xacro:macro>

  <!-- ============ D435 仿真相机 ============ -->
  <xacro:macro name="d435_camera" params="parent name xyz rpy">
    <joint name="${name}_joint" type="fixed">
      <origin xyz="${xyz}" rpy="${rpy}"/>
      <parent link="${parent}"/>
      <child link="${name}_link"/>
    </joint>
    <link name="${name}_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.025 0.015 0.01"/>
        </geometry>
        <material name="black"/>
      </visual>
      <inertial>
        <mass value="0.01"/>
        <inertia ixx="1e-6" iyy="1e-6" izz="1e-6" ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>

    <gazebo reference="${name}_link">
      <sensor name="${name}_rgb" type="camera">
        <always_on>true</always_on>
        <update_rate>30.0</update_rate>
        <visualize>true</visualize>
        <camera>
          <horizontal_fov>1.089</horizontal_fov>
          <image>
            <width>240</width>
            <height>240</height>
            <format>R8G8B8</format>
          </image>
          <clip><near>0.01</near><far>10.0</far></clip>
        </camera>
      </sensor>
      <sensor name="${name}_depth" type="depth">
        <always_on>true</always_on>
        <update_rate>30.0</update_rate>
        <camera>
          <horizontal_fov>1.089</horizontal_fov>
          <image>
            <width>240</width>
            <height>240</height>
            <format>R_FLOAT32</format>
          </image>
          <clip><near>0.01</near><far>10.0</far></clip>
        </camera>
      </sensor>
    </gazebo>
  </xacro:macro>

</robot>
